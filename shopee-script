// Put your token here if required. Otherwise leave as null.
const AUTH_TOKEN = null; // e.g. "Bearer xxxxx" or null

const listUrl = "https://affiliate.shopee.ph/api/v3/offer/product/list?list_type=9&sort_type=1&page_offset=0&page_limit=50&client_type=1";
const gqlUrl = "https://affiliate.shopee.ph/api/v3/gql?q=productOfferLinks";

const commonHeaders = {
  "Accept": "application/json",
  "Content-Type": "application/json",
  ...(AUTH_TOKEN ? { "Authorization": AUTH_TOKEN } : {})
};

function chunkArray(arr, size) {
  const out = [];
  for (let i = 0; i < arr.length; i += size) out.push(arr.slice(i, i + size));
  return out;
}

const gqlQuery = `
query batchGetProductOfferLink (
  $sourceCaller: SourceCaller!
  $productOfferLinkParams: [ProductOfferLinkParam!]!
  $advancedLinkParams: AdvancedLinkParams
){
  productOfferLinks(
    productOfferLinkParams: $productOfferLinkParams,
    sourceCaller: $sourceCaller,
    advancedLinkParams: $advancedLinkParams
  ) {
    itemId
    shopId
    productOfferLink
  }
}
`;

/**
 * Fetch the product list then fetch promo links in batches.
 * Returns array of products with additional field `productOfferLink` (if found).
 */
async function fetchShopeeOffersWithPromoLinks() {
  try {
    // 1) get the product list
    const listResp = await fetch(listUrl, {
      method: "GET",
      headers: commonHeaders
    });

    if (!listResp.ok) throw new Error(`List request failed: ${listResp.status}`);

    const listJson = await listResp.json();
    const products = (listJson?.data?.list) ? Array.from(listJson.data.list) : [];

    if (!products.length) {
      console.log("No products returned from list endpoint.");
      return [];
    }

    // Prepare params for each product
    const productParams = products.map(p => {
      const shopId = p?.batch_item_for_item_card_full?.shopid ?? p?.shopid ?? p?.shop_id ?? null;
      return {
        itemId: Number(p.item_id),
        shopId: Number(shopId),
        trace: p.trace ?? ""
      };
    }).filter(x => Number.isFinite(x.itemId) && Number.isFinite(x.shopId));

    // 2) chunk into batches to reduce number of POST requests
    const BATCH_SIZE = 10; // adjust if needed to avoid rate limits
    const batches = chunkArray(productParams, BATCH_SIZE);

    // Map to find returned links quickly
    const linkMap = new Map();

    for (const batch of batches) {
      const body = {
        operationName: "batchGetProductOfferLink",
        query: gqlQuery,
        variables: {
          productOfferLinkParams: batch,
          sourceCaller: "WEB_SITE_CALLER",
          advancedLinkParams: {
            subId1: "",
            subId2: "",
            subId3: "",
            subId4: "",
            subId5: ""
          }
        }
      };

      const resp = await fetch(gqlUrl, {
        method: "POST",
        headers: commonHeaders,
        body: JSON.stringify(body)
      });

      if (!resp.ok) {
        console.warn(`GQL request failed for batch (status ${resp.status}). Continuing with next batch.`);
        continue;
      }

      const json = await resp.json();
      const returned = json?.data?.productOfferLinks ?? [];

      returned.forEach(r => {
        const key = `${r.itemId}:${r.shopId}`;
        linkMap.set(key, r.productOfferLink);
      });

      // small delay to be friendlier to the API (adjust or remove as needed)
      await new Promise(resolve => setTimeout(resolve, 150));
    }

    // 3) attach productOfferLink to original product objects
    const productsWithLinks = products.map(p => {
      const shopId = p?.batch_item_for_item_card_full?.shopid ?? p?.shopid ?? p?.shop_id ?? null;
      const key = `${Number(p.item_id)}:${Number(shopId)}`;
      return {
        ...p,
        productOfferLink: linkMap.get(key) ?? null
      };
    });

    console.log("Products with promo links:", productsWithLinks);
    return productsWithLinks;

  } catch (err) {
    console.error("Error in fetchShopeeOffersWithPromoLinks:", err);
    throw err;
  }
}

/**
 * Save JSON data to a file.
 * - In browser: triggers download of filename (e.g. "shopee-offers.json")
 * - In Node.js: writes file with fs.writeFileSync (path must be writable)
 *
 * @param {any} data
 * @param {string} filename
 */
async function saveAsJsonFile(data, filename = "shopee-offers.json") {
  const jsonStr = JSON.stringify(data, null, 2);

  // Browser environment
  if (typeof window !== "undefined" && typeof document !== "undefined") {
    try {
      const blob = new Blob([jsonStr], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      console.log(`Downloaded ${filename} in browser.`);
    } catch (err) {
      console.error("Failed to save file in browser:", err);
      throw err;
    }
    return;
  }

  // Node.js environment
  if (typeof process !== "undefined" && process.versions && process.versions.node) {
    try {
      const fs = require("fs");
      const path = require("path");
      const outPath = path.resolve(process.cwd(), filename);
      fs.writeFileSync(outPath, jsonStr, "utf8");
      console.log(`Saved ${outPath} on server (Node.js).`);
      return;
    } catch (err) {
      console.error("Failed to save file in Node.js:", err);
      throw err;
    }
  }

  // Unknown environment
  throw new Error("Unknown environment: cannot save file automatically.");
}

// Example usage: fetch then save to JSON
fetchShopeeOffersWithPromoLinks()
  .then(list => {
    // Optionally do UI rendering etc here...
    list.forEach((p, i) => {
      console.log(`${i + 1}. itemId=${p.item_id}, shopId=${p.batch_item_for_item_card_full?.shopid ?? p.shopid}, link=${p.productOfferLink}`);
      console.log(`${p.batch_item_for_item_card_full?.name}`);
      console.log(`${p.batch_item_for_item_card_full?.images}`);
      try {
        console.log(`${p.batch_item_for_item_card_full?.video_info_list[0].video_id}`);
      } catch (err) {}
    });

    // Save the raw list + fetched promo links to a JSON file
    saveAsJsonFile(list, `shopee-offers-${Date.now()}.json`)
      .then(() => console.log("Save complete."))
      .catch(e => console.error("Save failed:", e));
  })
  .catch(e => {
    console.error("Final error:", e);
  });
