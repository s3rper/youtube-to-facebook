# Facebook Configuration
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key

# Anthropic API (for AI content generation)
ANTHROPIC_API_KEY=your_anthropic_api_key

# NewsData API (for news automation)
NEWSDATA_API_KEY=your_newsdata_api_key

# News Automation Settings
NEWS_MIN_WAIT_TIME=900000     # 15 minutes in milliseconds
NEWS_MAX_WAIT_TIME=3600000    # 1 hour in milliseconds
NEWS_DAILY_POST_LIMIT=24      # Up to 24 posts per day (hourly posting)

# Duterte Video Automation Settings
VIDEO_MIN_WAIT_TIME=3600000      # 1 hour in milliseconds
VIDEO_MAX_WAIT_TIME=3600000      # 1 hour in milliseconds
VIDEO_DAILY_POST_LIMIT=24        # 24 videos per day (1 per hour)

# Trending Video Automation Settings
TRENDING_MIN_VIEWS=0                  # Minimum views for trending videos
TRENDING_MIN_VIEW_VELOCITY=0           # Minimum views per hour
TRENDING_MIN_ENGAGEMENT_RATE=0.05         # Minimum engagement rate (5%)
TRENDING_MAX_VIDEO_AGE_HOURS=72           # Maximum video age in hours (3 days for more Shorts)
TRENDING_DAILY_POST_LIMIT=12              # 12 videos per day (half of main automation)
TRENDING_MIN_WAIT_TIME=3600000            # 1 hour in milliseconds
TRENDING_MAX_WAIT_TIME=3600000            # 1 hour in milliseconds
TRENDING_ACCEPTED_LANGUAGES=en,tl,fil     # Accepted languages (English, Tagalog, Filipino)